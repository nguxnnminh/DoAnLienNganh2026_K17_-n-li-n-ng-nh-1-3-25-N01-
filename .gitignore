# ================================================================
# NOVA Clothing Store — .gitignore
# Team goal: git pull → run → everything works
# ================================================================

# ────────────────────────────────────────────────────────────────
# SPRING BOOT / MAVEN
# ────────────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar

# ────────────────────────────────────────────────────────────────
# IDE (personal config — do not commit)
# ────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache
.apt_generated
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# ────────────────────────────────────────────────────────────────
# SECRETS — NEVER commit
# ────────────────────────────────────────────────────────────────
.env
.env.*
application-local.properties
application-secret.properties
*.pem
*.key
*.p12
*.jks
mobile-app/android/key.properties

# ────────────────────────────────────────────────────────────────
# LOGS & OS
# ────────────────────────────────────────────────────────────────
*.log
logs/
.DS_Store
Thumbs.db

# ────────────────────────────────────────────────────────────────
# NODE (Tailwind build tooling)
# ────────────────────────────────────────────────────────────────
node_modules/

# ────────────────────────────────────────────────────────────────
# UPLOADS
# Include: products/ (demo product images — team needs these)
# Exclude: tryon-* (temp AI try-on files, large & regeneratable)
# ────────────────────────────────────────────────────────────────
uploads/tryon-persons/
uploads/tryon-garments/

# ────────────────────────────────────────────────────────────────
# CLAUDE CODE — local AI assistant state
# ────────────────────────────────────────────────────────────────
.claude/

# ────────────────────────────────────────────────────────────────
# FLUTTER
# Committed:   pubspec.yaml, pubspec.lock, lib/, assets/fonts/, android/*, ios/*
# Not committed: build output, local machine cache files
# ────────────────────────────────────────────────────────────────

# Build output
mobile-app/build/

# Dart tool cache (auto-recreated by flutter pub get)
mobile-app/.dart_tool/
mobile-app/.packages
mobile-app/.flutter-plugins
mobile-app/.flutter-plugins-dependencies

# Android local machine files (auto-created by Android Studio/SDK)
mobile-app/android/.gradle/
mobile-app/android/local.properties

# iOS build artifacts
mobile-app/ios/Pods/
mobile-app/ios/.symlinks/
mobile-app/ios/Flutter/.last_build_id

# ────────────────────────────────────────────────────────────────
# GRADLE local cache
# ────────────────────────────────────────────────────────────────
.gradle/

# ────────────────────────────────────────────────────────────────
# PYTHON TRY-ON SERVER
# ────────────────────────────────────────────────────────────────
python-tryon-server/__pycache__/
**/__pycache__/
python-tryon-server/*.pyc
python-tryon-server/venv/
python-tryon-server/.venv/
python-tryon-server/python          # junk empty file from a stray shell redirect

# Local CatVTON model weights (~4GB) — fetch via `python download_models.py`
python-tryon-server/weights/

# OOTDiffusion model weights (~10GB) — legacy, no longer used
python-tryon-server/OOTDiffusion/

# CatVTON source (3rd-party clone, ~38MB, has its own .git) — see README to clone separately
python-tryon-server/catvton_src/

# Model binaries anywhere — never commit these
*.pth
*.pkl
*.safetensors
*.bin
*.onnx
*.ckpt
*.gguf

# HuggingFace / Torch caches if they ever land in-repo
.cache/
hf_cache/
